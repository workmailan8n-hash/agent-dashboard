{
  "name": "agent-dashboard",
  "version": "2.0.0",
  "description": "",
  "main": "server.js",
  "scripts": {
    "dev": "concurrently -n srv,vite,sync -c green,magenta,cyan \"node server.js\" \"npx vite\" \"node sync-to-cloud.js\"",
    "dev:nosync": "concurrently -n srv,vite -c green,magenta \"node server.js\" \"npx vite\"",
    "build": "npx vite build",
    "start": "node server.js",
    "preview": "npx vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npx playwright test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "chokidar": "^3.6.0",
    "dotenv": "^17.4.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.4.2",
    "vite": "^8.0.3",
    "vitest": "^2.1.8"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,css}": "prettier --write"
  }
}
